{
    "name": "ish-sales-accelerator-d365",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3002 -H 0.0.0.0",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:seed": "tsx src/db/seed.ts",
        "db:studio": "drizzle-kit studio",
        "test": "vitest run",
        "db:seed-superadmin": "tsx scripts/seed-superadmin.ts",
        "db:apply-sql": "tsx scripts/apply-sql-migrations.ts",
        "test:unit": "vitest run --config vitest.unit.config.ts",
        "test:eval": "vitest run --config vitest.unit.config.ts src/lib/eval/golden-emails.test.ts",
        "test:api": "vitest run --config vitest.api.config.ts",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
        "db:seed-test-user": "tsx scripts/seed-test-user.ts",
        "cap:sync": "npx cap sync",
        "cap:ios": "npm run cap:sync:ios && npx cap open ios",
        "cap:android": "npm run cap:sync:android && npx cap open android",
        "cap:init": "npx cap add ios && npx cap add android",
        "cap:sync:android": "CAPACITOR_ANDROID=1 npx cap sync android",
        "cap:sync:ios": "CAPACITOR_TARGET=ios npx cap sync ios",
        "dev:mobile": "next dev -p 3002 -H 0.0.0.0",
        "cap:sync:android:dev": "CAPACITOR_USE_LOCAL=1 CAPACITOR_ANDROID=1 npx cap sync android",
        "cap:android:dev": "npm run cap:sync:android:dev && npx cap open android"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^3.0.85",
        "@ai-sdk/google": "^3.0.83",
        "@ai-sdk/openai": "^3.0.74",
        "@base-ui/react": "^1.6.0",
        "@capacitor/android": "^8.4.1",
        "@capacitor/camera": "^8.2.0",
        "@capacitor/cli": "^8.4.1",
        "@capacitor/core": "^8.4.1",
        "@capacitor/geolocation": "^8.2.0",
        "@capacitor/haptics": "^8.0.2",
        "@capacitor/ios": "^8.4.1",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^8.0.2",
        "@googlemaps/google-maps-services-js": "^3.4.2",
        "@neondatabase/serverless": "^1.1.0",
        "@radix-ui/react-avatar": "^1.2.0",
        "@radix-ui/react-dialog": "^1.1.17",
        "@radix-ui/react-dropdown-menu": "^2.1.18",
        "@radix-ui/react-separator": "^1.1.10",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-tabs": "^1.1.15",
        "@radix-ui/react-tooltip": "^1.2.10",
        "@types/pg": "^8.20.0",
        "ai": "^6.0.208",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "imapflow": "^1.4.2",
        "inngest": "^3.54.2",
        "lucide-react": "^1.21.0",
        "mailparser": "^3.9.11",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "nodemailer": "^9.0.1",
        "pg": "^8.22.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "resend": "^6.14.0",
        "shadcn": "^4.11.0",
        "sonner": "^2.0.7",
        "stripe": "^22.3.0",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "web-push": "^3.6.7",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@tailwindcss/postcss": "^4",
        "@types/bcryptjs": "^2.4.6",
        "@types/mailparser": "^3.4.6",
        "@types/node": "^20",
        "@types/nodemailer": "^8.0.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@types/web-push": "^3.6.4",
        "eslint": "^9",
        "eslint-config-next": "16.2.9",
        "tailwindcss": "^4",
        "tsx": "^4.22.4",
        "typescript": "^5",
        "vitest": "^4.1.9"
    }
